# ====================================================================
# ROO CODE IGNORE - НАСТРОЙКИ ДЛЯ НОЧНОЙ СМЕНЫ
# ====================================================================

# Игнорируем гигабайты тяжелого зависимого и скомпилированного кода
node_modules/
.next/
out/
build/
dist/
.git/

# Игнорируем кэш и логи окружения
.npm/
*.log
.eslintcache

# Игнорируем медиа-файлы (чтобы ИИ не тратил контекст и память)
*.png
*.jpg
*.jpeg
*.svg
*.gif
*.ico
*.mp4
*.mp3
*.wav
*.pdf

# Игнорируем конфигурационные файлы бэкапов базы данных (если есть)
supabase/.branches/
supabase/.temp/

# Игнорируем боевые конфиги, чтобы ИИ их случайно не прочитал и не перезаписал
.env
.env.local
.env.production